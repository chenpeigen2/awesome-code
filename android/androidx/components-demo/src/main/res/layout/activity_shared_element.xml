<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Shared Element 转场动画"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="点击图片查看共享元素转场效果"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <ImageView
        android:id="@+id/ivShared"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:background="@color/primary"
        android:scaleType="centerCrop"
        android:transitionName="shared_image" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="说明"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="1. 两个 Activity 中的 View 需要设置相同的 transitionName\n2. 使用 ActivityOptions.makeSceneTransitionAnimation\n3. 支持 Shared 元素：ImageView、TextView、View 等"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

</LinearLayout>
