<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="有序广播示例"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="有序广播按优先级顺序传递，可以被拦截或修改数据"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnSendOrdered"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="发送有序广播" />

    <Button
        android:id="@+id/btnSendWithResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="发送并获取最终结果" />

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/log_bg"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="接收者说明"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="OrderedReceiverA (优先级100)\n- 可以修改数据\n- 可以调用 abortBroadcast() 拦截\n\nOrderedReceiverB (优先级50)\n- 接收 A 修改后的数据"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

</LinearLayout>
