<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Activity 基础"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="1. 显式 Intent 启动"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnExplicit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="显式启动 Activity" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="2. 隐式 Intent 启动"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnImplicit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="隐式启动 Activity" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="3. 数据传递方式"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnPassBasic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="传递基本类型" />

        <Button
            android:id="@+id/btnPassBundle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="传递 Bundle" />

        <Button
            android:id="@+id/btnPassParcelable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="传递 Parcelable 对象" />

        <Button
            android:id="@+id/btnPassSerializable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="传递 Serializable 对象" />

    </LinearLayout>

</ScrollView>
