<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 权限声明 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ComponentsDemo"
        tools:targetApi="31">

        <!-- 主入口 Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ==================== Activity 组件示例 ==================== -->

        <activity
            android:name=".activity.basic.BasicActivity"
            android:exported="false" />

        <activity
            android:name=".activity.basic.ExplicitIntentActivity"
            android:exported="false" />

        <activity
            android:name=".activity.basic.ImplicitIntentActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="components" android:host="demo" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activity.lifecycle.LifecycleNormalActivity"
            android:exported="false" />

        <activity
            android:name=".activity.lifecycle.LifecycleDialogActivity"
            android:exported="false"
            android:theme="@style/Theme.ComponentsDemo.Dialog" />

        <activity
            android:name=".activity.lifecycle.LifecycleTranslucentActivity"
            android:exported="false"
            android:theme="@style/Theme.ComponentsDemo.Translucent" />

        <activity
            android:name=".activity.launchmode.StandardActivity"
            android:exported="false" />

        <activity
            android:name=".activity.launchmode.SingleTopActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".activity.launchmode.SingleTaskActivity"
            android:exported="false"
            android:launchMode="singleTask" />

        <activity
            android:name=".activity.launchmode.SingleInstanceActivity"
            android:exported="false"
            android:launchMode="singleInstance" />

        <activity
            android:name=".activity.advanced.ActivityResultActivity"
            android:exported="false" />

        <activity
            android:name=".activity.advanced.CustomResultActivity"
            android:exported="false" />

        <activity
            android:name=".activity.advanced.FragmentCommunicationActivity"
            android:exported="false" />

        <activity
            android:name=".activity.advanced.SharedElementActivity"
            android:exported="false" />

        <activity
            android:name=".activity.advanced.TaskAffinityActivity"
            android:exported="false"
            android:taskAffinity="com.peter.components.task" />

        <!-- ==================== Service 组件示例 ==================== -->

        <activity
            android:name=".service.ServiceMainActivity"
            android:exported="false" />

        <service
            android:name=".service.basic.SimpleService"
            android:exported="false" />

        <service
            android:name=".service.foreground.DownloadService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="demo" />
        </service>

        <service
            android:name=".service.bind.LocalBindService"
            android:exported="false" />

        <service
            android:name=".service.bind.RemoteBindService"
            android:exported="true"
            android:process=":remote">
            <intent-filter>
                <action android:name="com.peter.components.demo.service.IRemoteService" />
            </intent-filter>
        </service>

        <!-- ==================== BroadcastReceiver 组件示例 ==================== -->

        <activity
            android:name=".receiver.SystemBroadcastActivity"
            android:exported="true" />

        <activity
            android:name=".receiver.OrderedBroadcastActivity"
            android:exported="false" />

        <activity
            android:name=".receiver.LocalBroadcastActivity"
            android:exported="false" />

        <receiver
            android:name=".receiver.StaticReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.ACTION_POWER_CONNECTED" />
                <action android:name="android.intent.action.ACTION_POWER_DISCONNECTED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.ordered.OrderedReceiverA"
            android:exported="true">
            <intent-filter android:priority="100">
                <action android:name="com.peter.components.demo.ORDERED_BROADCAST" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".receiver.ordered.OrderedReceiverB"
            android:exported="true">
            <intent-filter android:priority="50">
                <action android:name="com.peter.components.demo.ORDERED_BROADCAST" />
            </intent-filter>
        </receiver>

        <!-- ==================== ContentProvider 组件示例 ==================== -->

        <activity
            android:name=".provider.ProviderBasicActivity"
            android:exported="false" />

        <activity
            android:name=".provider.ProviderAdvancedActivity"
            android:exported="false" />

        <provider
            android:name=".provider.UserProvider"
            android:authorities="com.peter.components.demo.provider"
            android:exported="true" />

    </application>

</manifest>