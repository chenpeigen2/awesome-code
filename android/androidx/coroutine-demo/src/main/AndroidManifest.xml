<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Coroutine"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 协程基础模块 (01-Basics) -->
        <activity
            android:name=".basics.SuspendFunctionActivity"
            android:exported="false" />

        <activity
            android:name=".basics.LaunchAsyncActivity"
            android:exported="false" />

        <activity
            android:name=".basics.DispatchersActivity"
            android:exported="false" />

        <activity
            android:name=".basics.JobActivity"
            android:exported="false" />

        <activity
            android:name=".basics.CoroutineScopeActivity"
            android:exported="false" />

        <!-- Flow 模块 (02-Flow) -->
        <activity
            android:name=".flow.FlowBasicsActivity"
            android:exported="false" />

        <activity
            android:name=".flow.FlowOperatorsActivity"
            android:exported="false" />

        <activity
            android:name=".flow.StateFlowActivity"
            android:exported="false" />

        <activity
            android:name=".flow.ColdHotFlowActivity"
            android:exported="false" />

        <!-- Channel 模块 (03-Channel) -->
        <activity
            android:name=".channel.ChannelBasicsActivity"
            android:exported="false" />

        <activity
            android:name=".channel.ProduceConsumeActivity"
            android:exported="false" />

        <activity
            android:name=".channel.SelectExpressionActivity"
            android:exported="false" />

        <!-- 异常处理模块 (04-ErrorHandling) -->
        <activity
            android:name=".errorhandling.TryCatchActivity"
            android:exported="false" />

        <activity
            android:name=".errorhandling.ExceptionHandlerActivity"
            android:exported="false" />

        <activity
            android:name=".errorhandling.SupervisorJobActivity"
            android:exported="false" />

        <!-- Android 集成模块 (05-Android) -->
        <activity
            android:name=".android.LifecycleScopeActivity"
            android:exported="false" />

        <activity
            android:name=".android.ViewModelScopeActivity"
            android:exported="false" />

        <activity
            android:name=".android.CollectFlowActivity"
            android:exported="false" />

        <!-- 进阶原理模块 (06-Advanced) -->
        <activity
            android:name=".advanced.ContinuationActivity"
            android:exported="false" />

        <activity
            android:name=".advanced.StateMachineActivity"
            android:exported="false" />

        <activity
            android:name=".advanced.CustomScopeActivity"
            android:exported="false" />

        <activity
            android:name=".advanced.RoomExampleActivity"
            android:exported="false" />

    </application>

</manifest>
