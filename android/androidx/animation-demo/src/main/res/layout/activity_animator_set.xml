<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".propertyanimation.AnimatorSetActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:title="AnimatorSet"
            app:navigationIconTint="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 动画演示区域 -->
            <FrameLayout
                android:id="@+id/animationContainer"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_animation_area">

                <View
                    android:id="@+id/animationTarget1"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shape_animation_target" />

                <View
                    android:id="@+id/animationTarget2"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center|start"
                    android:background="@drawable/shape_animation_target_blue" />

                <View
                    android:id="@+id/animationTarget3"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center|end"
                    android:background="@drawable/shape_animation_target_orange" />

            </FrameLayout>

            <!-- 播放模式选择 -->
            <TextView
                android:id="@+id/tvPlayMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="播放模式"
                android:textSize="14sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgPlayMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbSequentially"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="顺序播放 (playSequentially)" />

                <RadioButton
                    android:id="@+id/rbTogether"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="同时播放 (playTogether)" />

                <RadioButton
                    android:id="@+id/rbBuilder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="复杂编排 (Builder)" />

            </RadioGroup>

            <!-- 时长调节 -->
            <TextView
                android:id="@+id/tvDurationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="单个动画时长: 500ms" />

            <SeekBar
                android:id="@+id/seekBarDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="2000"
                android:progress="500" />

            <!-- 控制按钮 -->
            <LinearLayout
                android:id="@+id/controlsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="播放" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="重置" />

            </LinearLayout>

            <!-- 代码说明 -->
            <TextView
                android:id="@+id/tvCodeHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/bg_code_block"
                android:textSize="12sp"
                android:textColor="#333333"
                android:fontFamily="monospace" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
