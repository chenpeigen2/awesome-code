<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    tools:context=".transitionanimation.SharedElementDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 共享元素：transitionName="shared_image" -->
        <ImageView
            android:id="@+id/ivImage"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:src="@drawable/shape_animation_target"
            android:transitionName="shared_image" />

        <!-- 共享元素：transitionName="shared_title" -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="共享元素演示"
            android:textSize="24sp"
            android:textStyle="bold"
            android:transitionName="shared_title" />

        <!-- 共享元素：transitionName="shared_desc" -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:text="这是详情页面，图片、标题和描述文字都从列表页面平滑过渡而来。\n\n共享元素动画可以让用户清楚地感知两个页面之间的关系，提供流畅的视觉体验。\n\n点击返回按钮或按返回键，可以看到反向的转场动画。"
            android:textSize="16sp"
            android:transitionName="shared_desc" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            android:layout_gravity="center"
            android:text="返回" />

    </LinearLayout>

</ScrollView>
