<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RxJava"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- RxJava 基础模块 -->
        <activity
            android:name=".basics.ObservableActivity"
            android:exported="false" />
        <activity
            android:name=".basics.SingleMaybeCompletableActivity"
            android:exported="false" />
        <activity
            android:name=".basics.DisposableActivity"
            android:exported="false" />

        <!-- 操作符模块 -->
        <activity
            android:name=".operators.TransformOperatorsActivity"
            android:exported="false" />
        <activity
            android:name=".operators.FilterOperatorsActivity"
            android:exported="false" />
        <activity
            android:name=".operators.CombineOperatorsActivity"
            android:exported="false" />

        <!-- 调度器模块 -->
        <activity
            android:name=".schedulers.SchedulersActivity"
            android:exported="false" />

        <!-- Subject 模块 -->
        <activity
            android:name=".subjects.SubjectsActivity"
            android:exported="false" />

        <!-- 错误处理模块 -->
        <activity
            android:name=".errorhandling.ErrorHandlingActivity"
            android:exported="false" />

        <!-- Android 集成模块 -->
        <activity
            android:name=".android.RxAndroidActivity"
            android:exported="false" />

    </application>

</manifest>
