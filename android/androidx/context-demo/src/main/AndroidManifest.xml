<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 文件读写权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".ContextDemoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Context"
        tools:targetApi="31">
        
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- 基础示例 -->
        <activity android:name=".basic.ContextTypeActivity" />
        <activity android:name=".basic.ContextResourcesActivity" />
        <activity android:name=".basic.ContextSharedPreferencesActivity" />
        <activity android:name=".basic.ContextFileActivity" />
        
        <!-- 进阶示例 -->
        <activity android:name=".advanced.ContextDatabaseActivity" />
        <activity android:name=".advanced.ContextSystemServicesActivity" />
        <activity android:name=".advanced.ContextWindowActivity" />
        
        <!-- 深入示例 -->
        <activity android:name=".deep.ContextWrapperActivity" />
        <activity android:name=".deep.ContextMemoryLeakActivity" />
        <activity android:name=".deep.ContextBestPracticesActivity" />
        
    </application>

</manifest>
