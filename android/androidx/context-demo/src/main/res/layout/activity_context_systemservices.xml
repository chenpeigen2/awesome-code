<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="系统服务示例"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnActivityManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activity"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnPowerManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Power"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnConnectivityManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnWifiManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WiFi"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnAudioManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnTelephonyManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telephony"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnSensorManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sensor"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnClipboardManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clipboard"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnInputMethodManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="InputMethod"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnVibrator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vibrator"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnAlarmManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alarm"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnNotificationManager"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notify"
                style="@style/Widget.Material3.Chip.Input" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/gray_dark"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/black"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>
