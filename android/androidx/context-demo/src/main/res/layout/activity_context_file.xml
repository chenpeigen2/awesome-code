<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 内部存储 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="内部存储 (Internal Storage)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="visible">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnInternalWrite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="写入"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnInternalRead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="读取"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnInternalDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="删除"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnInternalList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="列表"
                style="@style/Widget.Material3.Chip.Input" />

        </com.google.android.material.chip.ChipGroup>

        <!-- 缓存存储 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="缓存目录 (Cache)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnCacheWrite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="写入缓存"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnCacheRead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看缓存"
                style="@style/Widget.Material3.Chip.Input" />

        </com.google.android.material.chip.ChipGroup>

        <!-- 外部存储 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="外部存储 (External Storage)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnExternalWrite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="写入外部"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnExternalRead"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="读取外部"
                style="@style/Widget.Material3.Chip.Input" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/gray_dark"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/black"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>
