<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dialog 示例"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAlertDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AlertDialog"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnProgressDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="ProgressDialog"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnCustomDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="自定义Dialog"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnDatePickerDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="日期选择"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="悬浮窗示例"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnAddFloatingWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="添加悬浮窗"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnRemoveFloatingWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="移除悬浮窗"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="错误示例"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/error" />

        <Button
            android:id="@+id/btnDialogWithAppContext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="用 Application Context 创建 Dialog (会报错)"
            android:textSize="12sp"
            android:textColor="@color/error" />

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/gray_dark"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/black"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>
