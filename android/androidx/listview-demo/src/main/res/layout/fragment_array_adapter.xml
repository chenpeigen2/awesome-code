<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".fragment.ArrayAdapterFragment">

    <!-- 标题说明 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/tab_array_adapter"
        android:textAppearance="@style/TextAppearance.ListViewDemo.Title"
        android:background="@color/surface" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- ListView with EmptyView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ListView
            android:id="@+id/list_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            style="@style/Widget.ListViewDemo.ListView" />

        <include
            android:id="@+id/empty_view"
            layout="@layout/empty_view" />

    </FrameLayout>

</LinearLayout>
