<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/info" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="自定义 Window"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/error" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnBasicWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="基本悬浮窗"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnDraggableWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="可拖动悬浮窗"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnClosableWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="带关闭按钮"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnNotificationWindow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="通知样式"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnRemoveAllWindows"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="移除所有窗口"
                style="@style/Widget.Material3.Chip.Input" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/gray_dark"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/black"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>
