<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PopupWindow 示例"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/accent" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/btnShowAsDropDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="showAsDropDown"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnShowAtLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="showAtLocation"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnDismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关闭Popup"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnListPopup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="列表Popup"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnMenuPopup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="菜单Popup"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnCustomPopup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义Popup"
                style="@style/Widget.Material3.Chip.Input" />

            <com.google.android.material.chip.Chip
                android:id="@+id/btnFocusablePopup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="可输入Popup"
                style="@style/Widget.Material3.Chip.Input" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/gray_dark"
            android:lineSpacingExtra="2dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="@color/black"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</ScrollView>
