    <!-- Basic Fragment -->
    <string name="basic_title">@Inject 构造器注入</string>
    <string name="basic_description">Dagger2 的核心是三个注解：\n\n1. @Inject - 标记需要注入的依赖\n2. @Module - 定义如何提供依赖\n3. @Component - 连接注入点和依赖提供者</string>
    <string name="basic_brew">制作咖啡</string>
    <string name="basic_check_instance">检查实例</string>

    <!-- Scope Fragment -->
    <string name="scope_title">作用域 (Scope)</string>
    <string name="scope_description">Dagger2 通过作用域控制依赖的生命周期：\n\n@Singleton - 应用级单例\n无作用域 - 每次创建新实例</string>
    <string name="scope_singleton">@Singleton 测试</string>
    <string name="scope_no_scope">无作用域测试</string>
    <string name="scope_get_singleton">获取 Singleton</string>
    <string name="scope_get_request">获取 RequestService</string>

    <!-- Qualifier Fragment -->
    <string name="qualifier_title">限定符 (Qualifier)</string>
    <string name="qualifier_description">当同一接口有多个实现时，使用限定符区分：\n\n@LocalDataSource - 本地数据源\n@RemoteDataSource - 远程数据源</string>
    <string name="qualifier_local">本地数据源</string>
    <string name="qualifier_remote">远程数据源</string>
    <string name="qualifier_get_local">获取 Local</string>
    <string name="qualifier_get_remote">获取 Remote</string>

