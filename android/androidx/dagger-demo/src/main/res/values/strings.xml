    <!-- Basic Fragment -->
    <string name="basic_title">依赖注入核心注解</string>
    <string name="basic_description">Dagger2 三种提供依赖的方式：\n\n1. @Inject constructor() - 自动注入\n2. @Binds - 接口到实现的绑定\n3. @Provides - 带逻辑的依赖提供\n\n@Component 连接注入点和依赖提供者</string>
    <string name="basic_brew">制作咖啡</string>
