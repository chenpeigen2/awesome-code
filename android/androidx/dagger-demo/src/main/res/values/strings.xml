    <string name="scope_get_request">获取 RequestService</string>

    <!-- Qualifier Fragment -->
    <string name="qualifier_title">限定符</string>
    <string name="qualifier_description">当同一接口有多个实现时，使用限定符区分：\n\n@Named(\"local\") - 本地数据源\n@Named(\"remote\") - 远程数据源</string>
    <string name="qualifier_local">本地数据源</string>
    <string name="qualifier_remote">远程数据源</string>
    <string name="qualifier_get_local">获取 Local</string>
