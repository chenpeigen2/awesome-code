    <string name="subcomponent_title">子组件 (Subcomponent)</string>
    <string name="subcomponent_description">子组件可以继承父组件的依赖图：\n\n• 访问父组件的所有依赖\n• 拥有独立的作用域\n• 适合特定流程（如登录）</string>
    <string name="subcomponent_create">创建 LoginComponent</string>
    <string name="subcomponent_get_auth">获取 AuthService</string>
    <string name="subcomponent_get_repo">获取 UserRepository</string>

