<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 标题卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/tab_android_container"
            app:strokeWidth="1dp"
            app:strokeColor="@color/tab_android">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/android_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/tab_android" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/android_description"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ViewModel 注入 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/android_viewmodel"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/tab_android" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGetViewModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/android_get_viewmodel"
            app:cornerRadius="20dp"
            style="@style/Widget.Material3.Button.TonalButton" />

        <!-- 结果显示 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/code_background">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textSize="12sp"
                android:textColor="@color/code_text"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                tools:text="Android 集成测试..." />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>