<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 分类标题 -->
    <TextView
        android:id="@+id/tvCategoryHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:textAllCaps="true"
        android:letterSpacing="0.1"
        android:visibility="gone"
        tools:text="基础通知"
        tools:visibility="visible" />

    <!-- 卡片 - 使用 elevation + outlineSpotShadowColor 设置带颜色阴影 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        app:strokeWidth="0dp"
        app:rippleColor="#15000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- 颜色指示圆点 -->
            <View
                android:id="@+id/viewColorDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_color_dot" />

            <!-- 文本内容 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface"
                    tools:text="普通通知" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textSize="13sp"
                    android:textColor="@color/on_surface_variant"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="简单的标题和内容通知" />

            </LinearLayout>

            <!-- 箭头 -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_arrow_right"
                android:alpha="0.3"
                android:tint="@color/on_surface_variant"
                tools:ignore="ContentDescription" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
