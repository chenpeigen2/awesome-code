<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 说明卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/tertiary_container">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="分组通知"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#7D5260" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="点击卡片发送分组通知，多条通知会自动堆叠"
                    android:textSize="13sp"
                    android:textColor="#7D5260"
                    android:alpha="0.8" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 分组卡片容器 -->
        <LinearLayout
            android:id="@+id/containerGroups"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- 全局操作区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="20dp"
                android:background="@color/outline_variant"
                android:alpha="0.5" />

            <!-- 发送所有按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendAll"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="发送所有分组通知"
                android:textSize="14sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_send_all"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/primary"
                style="@style/Widget.Material3.Button" />

            <!-- 清除按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearAll"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="清除所有通知"
                android:textSize="14sp"
                app:icon="@drawable/ic_clear_all"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:cornerRadius="16dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
