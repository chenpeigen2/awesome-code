<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="自定义 LayoutInflater"
                    android:textColor="@color/purple_700"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="通过 cloneInContext() 可以克隆一个 LayoutInflater 并设置自定义行为，而不影响原有的 LayoutInflater 实例。"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- cloneInContext 说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="cloneInContext() 方法"
                    android:textColor="@color/teal_700"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="// 克隆 LayoutInflater，创建独立的副本\nval customInflater = layoutInflater\n  .cloneInContext(this)\n\n// 设置自定义 Factory\ncustomInflater.factory = MyFactory()\n\n// 使用自定义 inflater 加载布局\nval view = customInflater.inflate(\n  R.layout.xxx, container, false)"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 演示区域 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="示例演示"
            android:textColor="@color/purple_700"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="下面演示两个 LayoutInflater：\n• 原始 LayoutInflater - 普通加载\n• 自定义 LayoutInflater - 应用自定义 Factory"
            android:textColor="#757575"
            android:textSize="14sp" />

        <!-- 原始 LayoutInflater 结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="原始 LayoutInflater 加载结果"
            android:textColor="@color/teal_700"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/containerOriginal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#E0E0E0"
            android:minHeight="80dp"
            android:padding="8dp" />

        <!-- 自定义 LayoutInflater 结果 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="自定义 LayoutInflater 加载结果（应用 Factory）"
            android:textColor="@color/teal_700"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/containerCustom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#E0E0E0"
            android:minHeight="80dp"
            android:padding="8dp" />

        <!-- 对比说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="关键代码"
                    android:textColor="@color/purple_700"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="// 1. 克隆 LayoutInflater\nval customInflater = \n  layoutInflater.cloneInContext(this)\n\n// 2. 设置自定义 Factory\ncustomInflater.factory = object : LayoutInflater.Factory {\n  override fun onCreateView(\n    name: String,\n    context: Context,\n    attrs: AttributeSet\n  ): View? {\n    if (name == \&quot;TextView\&quot;) {\n      // 创建自定义 TextView\n      val tv = TextView(context)\n      tv.setTypeface(null, Typeface.ITALIC)\n      tv.setTextColor(Color.MAGENTA)\n      return tv\n    }\n    return null\n  }\n}\n\n// 3. 使用自定义 inflater 加载\nval view = customInflater.inflate(\n  R.layout.item_sample, container, false)"
                    android:textColor="@color/black"
                    android:textSize="11sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 应用场景 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="应用场景"
                    android:textColor="@color/purple_700"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1. 【局部样式】只对特定部分的 View 应用自定义样式\n\n2. 【插件化】动态加载插件中的布局，使用独立的 LayoutInflater\n\n3. 【皮肤切换】不同的 inflater 对应不同的皮肤主题\n\n4. 【安全隔离】限制某些布局中可用的 View 类型"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
