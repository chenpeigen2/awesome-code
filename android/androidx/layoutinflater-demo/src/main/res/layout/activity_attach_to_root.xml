<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="attachToRoot 参数深度解析"
                    android:textColor="@color/purple_700"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="attachToRoot 是 LayoutInflater.inflate() 最容易混淆的参数。本示例详细展示不同参数组合的效果。"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 测试布局预览 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="待加载的布局 (item_attach_demo.xml)"
                    android:textColor="@color/teal_700"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="&lt;LinearLayout\n  android:layout_width=&quot;match_parent&quot;\n  android:layout_height=&quot;80dp&quot;\n  android:layout_margin=&quot;8dp&quot;\n  android:background=&quot;@color/teal_200&quot; .../&gt;"
                    android:textColor="@color/black"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="注意：设置了 layout_margin 和固定高度 80dp"
                    android:textColor="#757575"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 场景一：root=null -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="场景一：inflate(resource, null)"
                    android:textColor="@color/error"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="val view = inflater.inflate(R.layout.xxx, null)\ncontainer.addView(view)"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• LayoutParams = null\n• layout_width/height/margin 全部失效\n• View 大小变成 WRAP_CONTENT 效果"
                    android:textColor="#757575"
                    android:textSize="12sp" />

                <FrameLayout
                    android:id="@+id/containerNull"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#E0E0E0"
                    android:minHeight="100dp"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/tvResultNull"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/purple_500"
                    android:textSize="11sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 场景二：root, false -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="场景二：inflate(resource, root, false) ✅ 推荐"
                    android:textColor="@color/success"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="val view = inflater.inflate(\n  R.layout.xxx, container, false)\ncontainer.addView(view)"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• LayoutParams 正确生成\n• layout_width/height/margin 全部生效\n• 需要手动 addView"
                    android:textColor="#757575"
                    android:textSize="12sp" />

                <FrameLayout
                    android:id="@+id/containerFalse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#E0E0E0"
                    android:minHeight="100dp"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/tvResultFalse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/purple_500"
                    android:textSize="11sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 场景三：root, true -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="场景三：inflate(resource, root, true)"
                    android:textColor="@color/highlight"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="// 返回值是 root，不是加载的 View\nval returned = inflater.inflate(\n  R.layout.xxx, container, true)"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="• LayoutParams 正确生成\n• View 自动添加到 root\n• 返回值是 root 本身\n• 不需要手动 addView"
                    android:textColor="#757575"
                    android:textSize="12sp" />

                <FrameLayout
                    android:id="@+id/containerTrue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#E0E0E0"
                    android:minHeight="100dp"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/tvResultTrue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/purple_500"
                    android:textSize="11sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 总结卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="使用场景总结"
                    android:textColor="@color/purple_700"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="【attachToRoot = false】(推荐)\n• RecyclerView.Adapter.onCreateViewHolder\n• Fragment.onCreateView\n• Dialog 自定义布局\n• 需要延迟添加或条件添加\n\n【attachToRoot = true】\n• 动态添加 View 到容器\n• 立即添加到父容器的场景\n\n【root = null】(不推荐)\n• 仅在不需要 layout 属性时使用\n• 可通过 View.setLayoutParams 手动设置"
                    android:textColor="@color/black"
                    android:textSize="13sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
