<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LayoutInflater.Factory 机制"
                    android:textColor="@color/purple_700"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="LayoutInflater.Factory 允许你在 View 创建时进行拦截和自定义处理。这是一个高级用法，常用于：\n\n• 替换某些 View 类型\n• 自动注入通用属性\n• 实现皮肤切换\n• 性能监控和调试"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 接口说明 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Factory 接口定义"
                    android:textColor="@color/teal_700"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="interface Factory {\n  // 在创建 View 时被调用\n  // 返回 null 表示使用默认逻辑\n  fun onCreateView(\n    name: String,\n    context: Context,\n    attrs: AttributeSet\n  ): View?\n}"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 示例演示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="示例：自动替换所有 TextView 为自定义样式"
            android:textColor="@color/purple_700"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="下面的布局包含两个普通 TextView，但通过 Factory 自动替换为了自定义样式的 TextView："
            android:textColor="#757575"
            android:textSize="14sp" />

        <!-- 演示容器 -->
        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#E0E0E0"
            android:orientation="vertical"
            android:padding="16dp" />

        <!-- 原始布局对比 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="原始布局 XML (未应用 Factory)"
                    android:textColor="@color/teal_700"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="&lt;!-- 原始 TextView -->\n&lt;TextView\n  android:text=&quot;普通 TextView&quot;\n  android:textSize=&quot;14sp&quot; />\n\n&lt;!-- 应用 Factory 后 -->\n&lt;!-- 自动添加了字体和颜色 -->\n&lt;TextView\n  android:text=&quot;增强 TextView&quot;\n  android:textSize=&quot;14sp&quot;\n  android:textStyle=&quot;bold&quot;\n  android:textColor=&quot;#FF6200EE&quot; />"
                    android:textColor="@color/black"
                    android:textSize="11sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Factory 代码 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CustomFactory 实现"
                    android:textColor="@color/teal_700"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="#F5F5F5"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:text="class CustomFactory : LayoutInflater.Factory {\n  override fun onCreateView(\n    name: String,\n    context: Context,\n    attrs: AttributeSet\n  ): View? {\n    // 拦截 TextView 创建\n    if (name == \&quot;TextView\&quot;) {\n      val tv = TextView(context)\n      // 自动应用样式\n      tv.setTypeface(null, Typeface.BOLD)\n      tv.setTextColor(Color.parseColor(\&quot;#6200EE\&quot;))\n      return tv\n    }\n    return null // 使用默认逻辑\n  }\n}"
                    android:textColor="@color/black"
                    android:textSize="11sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 应用场景 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="典型应用场景"
                    android:textColor="@color/purple_700"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="1. 【皮肤切换】根据主题替换 View 类型\n\n2. 【字体注入】自动为所有 TextView 设置自定义字体\n\n3. 【监控调试】记录 View 创建信息，用于性能分析\n\n4. 【无障碍适配】自动添加内容描述或放大可点击区域\n\n5. 【AOP 思想】统一添加点击防抖、埋点等功能"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
