{
  "name": "music-player",
  "version": "1.0.0",
  "description": "A desktop music player built with Electron, React and TypeScript",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "start": "npm run build:electron && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npx electron .\"",
    "start:win": "powershell -ExecutionPolicy Bypass -File ./start.ps1",
    "start:win-cmd": "start.bat",
    "start:mac": "chmod +x ./start.sh && ./start.sh",
    "start:linux": "chmod +x ./start.sh && ./start.sh",
    "electron:dev": "concurrently \"npm run build:electron && tsc -p electron/tsconfig.json -w\" \"vite\" \"wait-on http://localhost:5173 && wait-on dist/electron/main.js && electron .\"",
    "electron:build": "npm run build:electron && vite build && electron-builder",
    "electron:build:win": "npm run build:electron && vite build && electron-builder --win",
    "electron:build:mac": "npm run build:electron && vite build && electron-builder --mac",
    "electron:build:linux": "npm run build:electron && vite build && electron-builder --linux",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/howler": "^2.2.11",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "happy-dom": "^20.6.1",
    "jsdom": "^28.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.musicplayer.app",
    "productName": "Music Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
