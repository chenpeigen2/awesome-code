# 示例配置文件
# 复制此文件为 .env 并填入实际值

# Unsplash API 密钥
# 获取地址: https://unsplash.com/developers
IMAGEVIEWER_UNSPLASH_API_KEY=

# Google Custom Search API 密钥和搜索引擎ID
# 获取地址: https://developers.google.com/custom-search/v1/introduction
IMAGEVIEWER_GOOGLE_API_KEY=
IMAGEVIEWER_GOOGLE_SEARCH_ENGINE_ID=

# Bing Image Search API 密钥
# 获取地址: https://azure.microsoft.com/en-us/services/cognitive-services/bing-image-search-api/
IMAGEVIEWER_BING_API_KEY=

# 下载目录
IMAGEVIEWER_DOWNLOAD_DIR=~/Pictures/ImageViewer

# 收藏夹目录
IMAGEVIEWER_COLLECTIONS_DIR=~/Pictures/ImageViewer/Collections

# 缩略图大小
IMAGEVIEWER_THUMBNAIL_SIZE=200

# 最大并发下载数
IMAGEVIEWER_MAX_CONCURRENT_DOWNLOADS=3

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
IMAGEVIEWER_LOG_LEVEL=INFO

# 日志文件名
IMAGEVIEWER_LOG_FILE=imageviewer.log
